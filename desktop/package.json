{
  "name": "qr-remote-input-browser",
  "version": "1.0.0",
  "description": "Trinh duyet desktop nhan du lieu QR tu dien thoai qua Firebase, go truc tiep vao vi tri con tro",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.h.qrremoteinput",
    "productName": "QR Remote Input Browser",
    "files": [
      "**/*",
      "!dist/**"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
